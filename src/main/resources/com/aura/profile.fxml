<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.GridPane?>

<GridPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.aura.ProfileController" hgap="10" vgap="10" styleClass="content">
    <Label text="Modificar Perfil" styleClass="heading" GridPane.columnSpan="2" />
    <Label text="Nombre:" GridPane.rowIndex="1"/>
    <TextField fx:id="nameField" GridPane.rowIndex="1" GridPane.columnIndex="1" />
    <Label text="Correo:" GridPane.rowIndex="2"/>
    <TextField fx:id="emailField" GridPane.rowIndex="2" GridPane.columnIndex="1" />
    <Button text="Guardar" fx:id="btnSave" onAction="#onSave" GridPane.rowIndex="3" GridPane.columnSpan="2" />
</GridPane>
